{
  name: "Default",
  image: "ubuntu:latest",
  customizations : {
    jetbrains : {
      backend : "IntelliJ",
      settings : {},
      plugins: []
    }
  },
  "mounts": [
    "source=${env:USERPROFILE}${env:HOME}/.config/sops/age/keys.txt,target=/.jbdevcontainer/config/sops/age/keys.txt,type=bind,consistency=cached",
    "source=${env:USERPROFILE}${env:HOME}/.ssh/config,target=/etc/ssh/ssh_config.d/default.conf,type=bind,consistency=cached"
  ],
  features: {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "upgradePackages": true,
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "installOhMyZshConfig": true
    },
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "curl,wget,age,jq,openssh-client"
    },
    "ghcr.io/devcontainers-extra/features/age:1": {},
    "ghcr.io/devcontainers/features/git" : {},
    "ghcr.io/mpriscella/features/sops:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  remoteUser: "root"
}